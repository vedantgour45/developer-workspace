# Supabase keys for the Notes MFE. Use the SAME values you put in
# apps/host/.env.local — the MFE reads the host's session from
# localStorage and talks to the same Supabase project for docs data.
#
# Copy this file to `.env.local` and fill in the values.
# If blank, the MFE falls back to localStorage demo mode.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional. URL where the Puppeteer-backed PDF service is listening.
# Defaults to http://localhost:5051 (matches apps/pdf-service).
VITE_PDF_SERVICE_URL=
