# Supabase authentication. Get these from your Supabase project dashboard:
#   https://app.supabase.com/project/_/settings/api
#
# Copy this file to `.env.local` (or `.env`) and fill in the values.
# If either value is blank, the workspace runs in demo mode (no auth, local-only).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
