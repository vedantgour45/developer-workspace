# Supabase keys for the Tasks MFE. Use the SAME values you put in
# apps/host/.env.local — the MFE reads the host's session from
# localStorage and talks to the same Supabase project for tasks
# and activity data.
#
# Copy this file to `.env.local` and fill in the values.
# If blank, the MFE falls back to localStorage demo mode.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
